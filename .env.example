# ============================================================
# BioPay Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# App
APP_NAME=BioPay
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-very-long-random-secret-key-in-production

# Database
POSTGRES_USER=biopay
POSTGRES_PASSWORD=biopay_secret_change_me
POSTGRES_DB=biopay_db
DATABASE_URL=postgresql+asyncpg://biopay:biopay_secret_change_me@postgres:5432/biopay_db

# Redis
REDIS_PASSWORD=redis_secret_change_me
REDIS_URL=redis://:redis_secret_change_me@redis:6379/0

# JWT
JWT_SECRET_KEY=change-me-to-another-very-long-random-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# WebAuthn / FIDO2
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=BioPay
WEBAUTHN_ORIGIN=https://localhost

# Session
SESSION_TIMEOUT_MINUTES=15

# CORS
CORS_ORIGINS=["http://localhost", "https://localhost", "http://localhost:3000"]

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Frontend
FLASK_SECRET_KEY=change-me-flask-secret-key
API_BASE_URL=http://backend:8000
